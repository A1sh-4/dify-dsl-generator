# Virtual environment — always run scripts via .venv/Scripts/python
.venv/
venv/
ENV/
env/

# Temporary plans, notes, scratch files (store here, never commit)
plans/
tmp/
temp/
*.tmp

# Secrets and local config
*.local.json
.env
*.env.*

# Python cache and test artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.pytest_cache/
*.egg-info/
dist/
build/

# Generated DSL output (user-generated files, not part of the plugin)
output/

# Scratch/test DSL exports dropped in the repo root (not part of the plugin).
# Anchored with a leading slash so real assets under skills/ are NOT ignored.
/*.yml
/*.yaml

# Test-run YAMLs
skills/dify/tests/*.yml

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~
